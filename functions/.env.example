# Non-secret function parameters. The REAL values live in the committed file
# `functions/.env.baby-answers` (project-scoped; read by Firebase at deploy time,
# and required so CI can deploy non-interactively). This .example is just a template.
#
# The Gemini API KEY is NOT here — it's the `AI_API_KEY` Cloud Functions secret.

# Provider for the Ask box: gemini | anthropic | openai. Recommended: gemini.
AI_PROVIDER=gemini
# Model. Blank falls back to the code default; we pin the auto-latest Flash alias.
AI_MODEL=gemini-flash-latest
